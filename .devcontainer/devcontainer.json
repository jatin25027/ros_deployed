{
  "name": "ROS Simulation Dashboard",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "forwardPorts": [7860],
  "portsAttributes": {
    "7860": {
      "label": "Web Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "node server.js",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
